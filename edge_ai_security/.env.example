# ── Hardware ──────────────────────────────────────────
# Options: rpi5_hailo | jetson_orin | cpu_only
HARDWARE_TARGET=cpu_only

# ── Cameras ───────────────────────────────────────────
# source: integer = USB webcam index, string = RTSP URL
CAM_0_SOURCE=0
CAM_0_LABEL=Dev Camera
# CAM_1_SOURCE=rtsp://admin:pass@192.168.1.100/stream1
# CAM_1_LABEL=Locker Room

# ── ZeroMQ ports (internal Docker network) ────────────
ZMQ_RAW_FRAMES_PORT=5550
ZMQ_MOTION_PORT=5551
ZMQ_DETECTIONS_PORT=5552
ZMQ_VIOLATIONS_PORT=5553
ZMQ_HEALTH_PORT=5554

# ── Inference ─────────────────────────────────────────
# device options: cpu | cuda | hailo
INFERENCE_DEVICE=cpu
YOLO_MODEL_PATH=/models/yolo11n.onnx
DETECTION_CONFIDENCE=0.50
FRAME_SKIP=3

# ── Motion detection ──────────────────────────────────
# Minimum pixel area to count as real motion
MOTION_MIN_AREA=500
MOTION_BLUR_SIZE=21
MOTION_HISTORY=500

# ── Storage ───────────────────────────────────────────
DATA_DIR=/data
MODELS_DIR=/models
CLIPS_DIR=/data/clips

# ── Media buffer ──────────────────────────────────────
# Seconds of video kept in RAM before a violation
BUFFER_SECONDS=60

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
